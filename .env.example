# Get your free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
# Secret used to sign/encrypt JWTs and session cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─── RBAC Configuration ─────────────────────────────────────────────────────
# Path to the SQLite database file for user/role storage.
# Defaults to ./data/rbac.db if not set.
# RBAC_DB_PATH=./data/rbac.db

# ─── Database Connectivity (optional) ───────────────────────────────────────
# These values are provided by the browser at runtime via the connection modal.
# They are NEVER read from the server environment or stored server-side.
# They are listed here for documentation purposes only.
#
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_NAME=your_database_name

# ─── Demo Database (optional) ───────────────────────────────────────────────
# Pre-configured demo database that visitors can use to try the app.
# If set, a "Try Demo DB" button appears for logged-in users.
DEMO_DB_HOST=your-aiven-host.aiven.io
DEMO_DB_PORT=12345
DEMO_DB_USER=avnadmin
DEMO_DB_PASSWORD=your_aiven_password
DEMO_DB_NAME=defaultdb
